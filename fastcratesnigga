local ReplicatedStorage = game:GetService("ReplicatedStorage")
local remote = ReplicatedStorage.Events.Crate.open

-- 1. DATA PERSISTENCE
_G.ActiveSelections = _G.ActiveSelections or {} 

local fullCrateList = {
    "Hell", "Heaven", "Music", "Cyber", "Steampunk", "Graffiti", "Vampiric", "Construction", "Manga", "Samurai", 
    "Royal", "Magma", "Ghost", "Abandoned", "Haunted", "Celestial", "Red Moon", "Vortex", "Cursed", "Devilous",
    "Cage Bound", "Caged Energy", "Clockwork", "Coral", "Deep Sea", "DNA", "Enchanted Wood", "Foam", "Gear Work", 
    "Green Lantern", "Honey", "Infernus", "Iron Bound", "Mirror", "Moss", "Purple Curse", "Rib", "Robo", "Rune", "Paper Talisman"
}

-- 2. CLEANUP PREVIOUS UI
local oldUI = game:GetService("CoreGui"):FindFirstChild("Angelo_MultiCrate")
if oldUI then oldUI:Destroy() end

-- 3. UI SETUP
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
ScreenGui.Name = "Angelo_MultiCrate"
ScreenGui.DisplayOrder = 999
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 220, 0, 350)
MainFrame.Position = UDim2.new(0.5, -110, 0.5, -175)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.Active = true
MainFrame.Draggable = true 
MainFrame.ClipsDescendants = true
Instance.new("UICorner", MainFrame)

-- TOP BAR
local TopBar = Instance.new("Frame", MainFrame)
TopBar.Size = UDim2.new(1, 0, 0, 30)
TopBar.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
TopBar.BorderSizePixel = 0

local Title = Instance.new("TextLabel", TopBar)
Title.Size = UDim2.new(1, -40, 1, 0)
Title.Position = UDim2.new(0, 10, 0, 0)
Title.BackgroundTransparency = 1
Title.Text = "FAST CRATES"
Title.TextColor3 = Color3.fromRGB(0, 255, 150)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 14
Title.TextXAlignment = Enum.TextXAlignment.Left

-- MINIMIZE/MAXIMIZE
local MinBtn = Instance.new("TextButton", TopBar)
MinBtn.Size = UDim2.new(0, 30, 0, 30)
MinBtn.Position = UDim2.new(1, -30, 0, 0)
MinBtn.BackgroundTransparency = 1
MinBtn.Text = "-"
MinBtn.TextColor3 = Color3.new(1, 1, 1)
MinBtn.TextSize = 20
MinBtn.Font = Enum.Font.GothamBold

-- FIXED SCROLLING FRAME
local Scroll = Instance.new("ScrollingFrame", MainFrame)
Scroll.Size = UDim2.new(1, -10, 1, -40)
Scroll.Position = UDim2.new(0, 5, 0, 35)
Scroll.BackgroundTransparency = 1
Scroll.ScrollBarThickness = 3
Scroll.BorderSizePixel = 0
Scroll.ZIndex = 5

local List = Instance.new("UIListLayout", Scroll)
List.Padding = UDim.new(0, 5)
List.HorizontalAlignment = Enum.HorizontalAlignment.Center
List.SortOrder = Enum.SortOrder.LayoutOrder

-- FORCE CANVAS UPDATE (The fix for empty lists)
local function UpdateCanvas()
    Scroll.CanvasSize = UDim2.new(0, 0, 0, List.AbsoluteContentSize.Y + 10)
end
List:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)

-- MINIMIZE LOGIC
local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        MainFrame:TweenSize(UDim2.new(0, 220, 0, 30), "Out", "Quart", 0.3, true)
        MinBtn.Text = "+"
        Scroll.Visible = false
    else
        MainFrame:TweenSize(UDim2.new(0, 220, 0, 350), "Out", "Quart", 0.3, true)
        MinBtn.Text = "-"
        task.wait(0.3)
        Scroll.Visible = true
        UpdateCanvas()
    end
end)

-- 4. BUTTON GENERATION
for _, crateName in pairs(fullCrateList) do
    local Btn = Instance.new("TextButton", Scroll)
    Btn.Size = UDim2.new(1, -10, 0, 30)
    Btn.Text = crateName
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 12
    Btn.ZIndex = 6
    Instance.new("UICorner", Btn)
    
    local function UpdateBtn()
        Btn.BackgroundColor3 = _G.ActiveSelections[crateName] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(30, 30, 30)
        Btn.TextColor3 = _G.ActiveSelections[crateName] and Color3.new(0,0,0) or Color3.new(1,1,1)
    end

    UpdateBtn()
    Btn.MouseButton1Click:Connect(function()
        _G.ActiveSelections[crateName] = not _G.ActiveSelections[crateName]
        UpdateBtn()
    end)
end

-- 5. THE MULTI-FIRE BYPASS
task.spawn(function()
    while true do
        for crateName, isEnabled in pairs(_G.ActiveSelections) do
            if isEnabled then
                task.spawn(function()
                    pcall(function()
                        remote:InvokeServer(crateName, 6)
                    end)
                end)
            end
        end
        task.wait(0.8) 
    end
end)

UpdateCanvas() -- Initial force update
